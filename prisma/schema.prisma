generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  nome      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresas     Empresa[]
  usuarios     Usuario[]
  fornecedores Fornecedor[]
  produtos     Produto[]
}

model Empresa {
  id        String    @id @default(uuid())
  tenantId  String
  nome      String
  cnpj      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  usuarios     Usuario[]
  fornecedores Fornecedor[]
  produtos     Produto[]
  viveiros     Viveiro[]

  @@index([tenantId])
}

model Usuario {
  id        String @id @default(uuid())
  tenantId  String
  empresaId String
  nome      String
  email     String
  senha     String
  role      Role   @default(OPERADOR)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([email, tenantId])
  @@index([empresaId])
}

model Fornecedor {
  id        String  @id @default(uuid())
  tenantId  String
  empresaId String
  nome      String
  contato   String?
  telefone  String?
  documento  String? @unique
  email     String? @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  empresa Empresa @relation(fields: [empresaId], references: [id])

  ciclos Ciclo[]
  lotes  LoteEstoque[]

  @@index([empresaId])
}
enum UnitType {
  WEIGHT
  VOLUME
  OTHER
}
model Produto {
  id            String      @id @default(uuid())
  tenantId      String
  empresaId     String
  nome          String
  tipo          ProdutoTipo
  unidadeMedida String
  tipoUnidade   UnitType    @default(OTHER)
  unidadeBase   String?     @default("g")
  estoqueMinimo Decimal? @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  empresa Empresa @relation(fields: [empresaId], references: [id])

  lotes LoteEstoque[]

  @@index([empresaId])
}

model LoteEstoque {
  id                 String   @id @default(uuid())
  tenantId           String
  empresaId          String
  produtoId          String
  fornecedorId       String
  quantidadeInicial  Decimal
  quantidadeRestante Decimal
  custoUnitario      Decimal
  dataCompra         DateTime @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  produto    Produto    @relation(fields: [produtoId], references: [id])
  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id])

  @@index([empresaId,tenantId])
  
  consumoEstoques ConsumoEstoque[]
}

model ConsumoEstoque {
  id             String   @id @default(uuid())
  loteId         String
  quantidade     Decimal
  custoUnitario  Decimal
  custoTotal     Decimal

  referenciaId   String? // ex: cicloId
  referenciaTipo String? // ex: "CICLO"

  createdAt DateTime @default(now())

  lote LoteEstoque @relation(fields: [loteId], references: [id])
}

model Viveiro {
  id        String  @id @default(uuid())
  tenantId  String
  empresaId String
  nome      String
  tamanhoM2 Decimal
  status    String  @default("VAZIO")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  empresa Empresa @relation(fields: [empresaId], references: [id])

  ciclos Ciclo[]

  @@index([empresaId])
}

model Ciclo {
  id                 String    @id @default(uuid())
  tenantId           String
  empresaId          String
  viveiroId          String
  fornecedorLarvasId String
  dataInicio         DateTime  @default(now())
  dataFim            DateTime?
  quantidadeLarvas   Int
  custoLarvas        Decimal?
  precoEsperadoKg    Decimal?
  status             String    @default("ATIVO")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  viveiro          Viveiro    @relation(fields: [viveiroId], references: [id])
  fornecedorLarvas Fornecedor @relation(fields: [fornecedorLarvasId], references: [id])

  registros RegistroDiario[]

  @@index([empresaId])
  desbastes Desbaste[]
}

model RegistroDiario {
  id       String       @id @default(uuid())
  cicloId  String
  data     DateTime     @default(now())
  tipo     RegistroTipo
  detalhes Json

  createdAt DateTime @default(now())

  ciclo Ciclo @relation(fields: [cicloId], references: [id])
}

model Desbaste {
  id                  String   @id @default(uuid())

  cicloId             String
  ciclo               Ciclo    @relation(fields: [cicloId], references: [id])

  pesoTotalKg         Float
  pesoMedioGramas     Float

  quantidadeEstimado  Int

  valorKg             Float
  valorTotal          Float

  observacao          String?

  tenantId            String
  empresaId           String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([cicloId])
  @@index([tenantId, empresaId])
}

enum Role {
  ADMIN
  OPERADOR
}

enum ProdutoTipo {
  RACAO
  INSUMO
}

enum RegistroTipo {
  ALIMENTACAO
  USO_INSUMO
  BIOMETRIA
  DESPESCA_PARCIAL
}
